rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Verifica se o usuário é membro da agência
    function getAgencyMember(agencyId) {
      return get(/databases/$(database)/documents/agencies/$(agencyId)/members/$(request.auth.uid)).data;
    }

    function isAgencyMember(agencyId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/agencies/$(agencyId)/members/$(request.auth.uid));
    }

    function isAgencyAdmin(agencyId) {
      return isAgencyMember(agencyId) && getAgencyMember(agencyId).role == 'admin';
    }

    function isAgencyManager(agencyId) {
      return isAgencyMember(agencyId) && getAgencyMember(agencyId).role == 'manager';
    }

    function isAgencyViewer(agencyId) {
      return isAgencyMember(agencyId) && getAgencyMember(agencyId).role == 'viewer';
    }

    // Regra de Ouro: Isolamento de Cliente para Managers
    function canAccessClient(agencyId, clientId) {
      let member = getAgencyMember(agencyId);
      return isAgencyAdmin(agencyId) || 
             (isAgencyManager(agencyId) && (member.assignedClients == null || clientId in member.assignedClients)) ||
             (isAgencyViewer(agencyId) && (member.assignedClients == null || clientId in member.assignedClients));
    }

    // ============================================
    // COLLECTIONS
    // ============================================

    // Users collection
    match /users/{userId} {
      allow read, write: if isUser(userId);

      // Consent preferences (cookie banner, LGPD)
      match /consent/{consentId} {
        allow read, write: if isUser(userId);
      }
    }
    
    // Agencies Root
    match /agencies/{agencyId} {
      allow read: if isAgencyMember(agencyId);
      allow write: if isAgencyAdmin(agencyId);

      // Members subcollection
      match /members/{memberId} {
        allow read: if isAgencyMember(agencyId);
        allow write: if isAgencyAdmin(agencyId);
      }

      // Clients subcollection (Isolamento de Cliente)
      match /clients/{clientId} {
        allow read: if isAgencyMember(agencyId) && canAccessClient(agencyId, clientId);
        allow write: if isAgencyAdmin(agencyId) || (isAgencyManager(agencyId) && canAccessClient(agencyId, clientId));
        
        // Dados do Cliente (Funis, Eventos, etc. dentro do path do cliente)
        match /{allChildren=**} {
          allow read: if isAgencyMember(agencyId) && canAccessClient(agencyId, clientId);
          allow write: if isAgencyAdmin(agencyId) || (isAgencyManager(agencyId) && canAccessClient(agencyId, clientId));
        }
      }
    }

    // Conversations
    match /conversations/{conversationId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid;
      }
    }

    // Legacy/Global Collections (Migrar para agency/client path no futuro)
    // Por enquanto, bloqueamos acesso global se não for admin do sistema ou se não houver vínculo explícito

    match /tenants/{tenantId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);

      // Integrations subcollection
      match /integrations/{integrationId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
      }
    }
    
    match /funnels/{funnelId} {
      // list (collection query): query-safe — só checa userId
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // get (single doc): checa userId ou agency membership
      allow get: if isAuthenticated() && (
        (resource.data.agencyId != null && canAccessClient(resource.data.agencyId, resource.data.clientId)) ||
        (resource.data.userId == request.auth.uid)
      );
      // create: resource é null, usa request.resource
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // update/delete: checa recurso existente
      allow update, delete: if isAuthenticated() && (
        (resource.data.agencyId != null && canAccessClient(resource.data.agencyId, resource.data.clientId)) ||
        (resource.data.userId == request.auth.uid)
      );

      // Proposals e Decisions subcollections
      match /proposals/{proposalId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/funnels/$(funnelId)).data.userId == request.auth.uid;
      }
      match /decisions/{decisionId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/funnels/$(funnelId)).data.userId == request.auth.uid;
      }
      // Copy proposals — generated copy variants per funnel
      match /copyProposals/{copyProposalId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/funnels/$(funnelId)).data.userId == request.auth.uid;
      }
    }

    // Root decisions collection (API routes)
    match /decisions/{decisionId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Campaigns — created by API routes, read by client
    match /campaigns/{campaignId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Copy Decisions — feedback/decisions about generated copy
    match /copyDecisions/{copyDecisionId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /brands/{brandId} {
      // list (collection query): query-safe — só checa userId
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // get (single doc): checa userId ou agency membership
      allow get: if isAuthenticated() && (
        (resource.data.agencyId != null && canAccessClient(resource.data.agencyId, resource.data.clientId)) ||
        (resource.data.userId == request.auth.uid)
      );
      // create: resource é null, usa request.resource
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // update/delete: checa recurso existente
      allow update, delete: if isAuthenticated() && (
        (resource.data.agencyId != null && canAccessClient(resource.data.agencyId, resource.data.clientId)) ||
        (resource.data.userId == request.auth.uid)
      );

      // Audit logs — written by client on brand governance actions
      match /audit_logs/{logId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }

      // Notifications subcollection (unread count badge)
      match /notifications/{notifId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }

      // Spy Intelligence: Competitors
      match /competitors/{competitorId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;

        match /assets/{assetId} {
          allow read, write: if isAuthenticated() &&
            get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
        }
      }

      // Intelligence documents and keyword configs
      match /intelligence/{docId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;

        match /{nestedId=**} {
          allow read, write: if isAuthenticated() &&
            get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
        }
      }

      // Keywords Miner data
      match /keywords/{keywordId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }

      // Generated ads — output of AI ad generation
      match /generated_ads/{adId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }

      // Offer Lab — subcollection de ofertas da brand
      match /offers/{offerId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/brands/$(brandId)).data.agencyId != null
            ? canAccessClient(
                get(/databases/$(database)/documents/brands/$(brandId)).data.agencyId,
                get(/databases/$(database)/documents/brands/$(brandId)).data.clientId
              )
            : get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid
        );
        allow write: if isAuthenticated() && (
          get(/databases/$(database)/documents/brands/$(brandId)).data.agencyId != null
            ? (isAgencyAdmin(get(/databases/$(database)/documents/brands/$(brandId)).data.agencyId) ||
               (isAgencyManager(get(/databases/$(database)/documents/brands/$(brandId)).data.agencyId) &&
                canAccessClient(
                  get(/databases/$(database)/documents/brands/$(brandId)).data.agencyId,
                  get(/databases/$(database)/documents/brands/$(brandId)).data.clientId
                )))
            : get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid
        );
      }

      // TASK 1.5: Content Calendar — used by content-calendar.ts, approval-engine.ts, API routes
      match /content_calendar/{entryId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;

        // Approval history subcollection
        match /history/{historyId} {
          allow read, write: if isAuthenticated() &&
            get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
        }
      }

      // TASK 1.6: Copy DNA — used by content/analytics route
      match /copy_dna/{dnaId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }

      // TASK 1.7: Performance Metrics — read by client hook; write only via Admin SDK (cron ads-sync)
      match /performance_metrics/{metricId} {
        allow read: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
        allow write: if false; // Admin SDK only (cron bypasses rules)
      }

      // TASK 1.8: Social Interactions — read/write by social-inbox routes and engagement-scorer
      match /social_interactions/{interactionId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }

      // TASK 1.9 (brand path): Leads subcollection — used by intelligence engines and automation adapters
      match /leads/{leadId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;

        // Lead events subcollection
        match /events/{eventId} {
          allow read, write: if isAuthenticated() &&
            get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
        }
      }

      // TASK 1.10 (brand path): Transactions subcollection — used by attribution/bridge.ts
      match /transactions/{transactionId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brands/$(brandId)).data.userId == request.auth.uid;
      }
    }

    // Brand Assets
    match /brand_assets/{assetId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      match /chunks/{chunkId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/brand_assets/$(assetId)).data.userId == request.auth.uid;
      }
    }

    // Knowledge base (Authenticated Read, Admin Write via custom claims)
    match /knowledge/{chunkId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAgencyAdmin(request.auth.token.agencyId);
    }

    // R-1.2: Library — Public read, write restricted to owner
    match /library/{templateId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // TASK 1.9 (root): Leads — filtered by brandId in all queries; brandId must belong to the caller
    // NOTE: uses get() in list rule — required until API routes migrate to Admin SDK (Fase 2)
    match /leads/{leadId} {
      allow list: if isAuthenticated() &&
        get(/databases/$(database)/documents/brands/$(resource.data.brandId)).data.userId == request.auth.uid;
      allow get: if isAuthenticated() &&
        get(/databases/$(database)/documents/brands/$(resource.data.brandId)).data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // created by automation/cron via server routes
      allow update, delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/brands/$(resource.data.brandId)).data.userId == request.auth.uid;

      // Lead events subcollection (root path)
      match /events/{eventId} {
        allow read, write: if isAuthenticated() &&
          get(/databases/$(database)/documents/leads/$(leadId)).data != null &&
          get(/databases/$(database)/documents/brands/$(get(/databases/$(database)/documents/leads/$(leadId)).data.brandId)).data.userId == request.auth.uid;
      }
    }

    // TASK 1.10 (root): Transactions — filtered by brandId; used by attribution hook and journey.ts
    // NOTE: uses get() in list rule — required until API routes migrate to Admin SDK (Fase 2)
    match /transactions/{transactionId} {
      allow list: if isAuthenticated() &&
        get(/databases/$(database)/documents/brands/$(resource.data.brandId)).data.userId == request.auth.uid;
      allow get: if isAuthenticated() &&
        get(/databases/$(database)/documents/brands/$(resource.data.brandId)).data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // created by journey.ts (server-side)
      allow update, delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/brands/$(resource.data.brandId)).data.userId == request.auth.uid;
    }

    // Embedding cache — written by server-side API routes (no user auth context)
    // Keys are SHA-256 hashes of text; values are embedding vectors (not sensitive)
    match /query_cache/{cacheKey} {
      allow read: if true;
      allow write: if true;
    }

    // Bloqueio Global de Segurança (NUNCA deixar allow true aqui)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
